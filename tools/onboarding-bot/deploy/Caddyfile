# {$DOMAIN} — public URL users hit (e.g. botc.example.com)
# HTTPS is auto-provisioned via Let's Encrypt

{$DOMAIN} {
    encode zstd gzip

    # Stream buffers kept small to preserve SSE/NDJSON live delivery
    reverse_proxy web:3000 {
        flush_interval -1
        header_up X-Forwarded-Proto {scheme}
        header_up X-Real-IP {remote_host}
    }
}

