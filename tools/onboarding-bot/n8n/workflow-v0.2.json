      "position": [1020, 600],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const raw = $input.first().json.text || $input.first().json.output || '';\nlet parsed;\ntry {\n  const match = raw.match(/\\{[\\s\\S]*\\}/);\n  parsed = match ? JSON.parse(match[0]) : { intent: '其他', role_name: null };\n} catch (e) {\n  parsed = { intent: '其他', role_name: null };\n}\nreturn [{ json: parsed }];"
      }
