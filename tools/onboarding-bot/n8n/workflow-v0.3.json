    {
      "id": "55555555-0001-0000-0000-000000000003",
      "name": "Parse Intent",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1020,
        600
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const raw = $input.first().json.text || $input.first().json.output || '';\nlet parsed;\ntry {\n  const match = raw.match(/\\{[\\s\\S]*\\}/);\n  parsed = match ? JSON.parse(match[0]) : { intent: '其他', role_name: null, role_confidence: 0 };\n} catch (e) {\n  parsed = { intent: '其他', role_name: null, role_confidence: 0 };\n}\nreturn [{ json: parsed }];"
      }
    },
