    {
      "id": "88888888-0001-0000-0000-000000000003",
      "name": "Fuzzy Role Lookup",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1540,
        680
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const fs = require('fs');\nconst path = require('path');\n\nconst queries = $('Parse Intent').first().json.role_names || [];\nconst dir = '/knowledge/roles';\nconst files = fs.readdirSync(dir).filter(f => f.endsWith('.md'));\n\nfunction findMatch(query) {\n  const q = (query || '').trim();\n  if (!q) return null;\n  let m = files.find(f => f.replace('.md','') === q);\n  if (m) return m;\n  m = files.find(f => f.replace('.md','').includes(q));\n  if (m) return m;\n  m = files.find(f => {\n    const stem = f.replace('.md','');\n    return stem.length >= 2 && q.includes(stem);\n  });\n  return m || null;\n}\n\nconst results = queries.map(q => {\n  const file = findMatch(q);\n  if (file) {\n    return {\n      query: q,\n      found: true,\n      role: file.replace('.md',''),\n      content: fs.readFileSync(path.join(dir, file), 'utf8')\n    };\n  }\n  return { query: q, found: false, role: q, content: '' };\n});\n\nconst parts = results.map(r =>\n  r.found ? `### ${r.role}\\n\\n${r.content}` : `### ${r.query}（资料中未找到此角色）`\n);\nconst formatted = parts.join('\\n\\n---\\n\\n') || '（用户未指明具体角色）';\n\nreturn [{\n  json: {\n    results,\n    queries,\n    found_count: results.filter(r => r.found).length,\n    total_count: queries.length,\n    formatted\n  }\n}];"
      }
    },
