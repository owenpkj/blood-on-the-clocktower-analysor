    {
      "id": "55555555-0001-0000-0000-000000000003",
      "name": "Parse Intent",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1020,
        600
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const raw = $input.first().json.text || $input.first().json.output || '';\nlet parsed;\ntry {\n  const match = raw.match(/\\{[\\s\\S]*\\}/);\n  parsed = match ? JSON.parse(match[0]) : { intent: '其他', role_names: [], role_confidence: 0 };\n  if (parsed.role_names === undefined || parsed.role_names === null) parsed.role_names = [];\n  if (typeof parsed.role_names === 'string') parsed.role_names = [parsed.role_names];\n  if (!Array.isArray(parsed.role_names)) parsed.role_names = [];\n  if (parsed.role_name && parsed.role_names.length === 0) parsed.role_names = [parsed.role_name];\n} catch (e) {\n  parsed = { intent: '其他', role_names: [], role_confidence: 0 };\n}\nreturn [{ json: parsed }];"
      }
    },
