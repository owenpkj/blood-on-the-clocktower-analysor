      "name": "Read All Plays",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1540, 780],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const fs = require('fs');\nconst path = require('path');\nconst dir = '/knowledge/plays';\nconst files = fs.readdirSync(dir).filter(f => f.endsWith('.md'));\nconst content = files.map(f => `### ${f.replace('.md','')}\\n\\n` + fs.readFileSync(path.join(dir, f), 'utf8')).join('\\n\\n---\\n\\n');\nreturn [{ json: { content, files } }];"
      }
